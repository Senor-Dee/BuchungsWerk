# BuchungsWerk – Umgebungsvariablen (Beispielwerte)
# Kopiere diese Datei nach .env und trage echte Werte ein.
# .env wird NICHT ins Git-Repository eingecheckt.

# ── Backend (Pi: /home/senor_d/buchungswerk-backend/.env) ────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BW_JWT_SECRET=min-32-zeichen-langes-zufallspasswort-hier-eintragen

# ── Optional: PayPal ─────────────────────────────────────────────────────────
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=

# ── Optional: Stripe ─────────────────────────────────────────────────────────
# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...

# ── Optional: Plausible Analytics (DSGVO-konform, Cookie-frei) ───────────────
# Leer lassen = deaktiviert (kein Script wird geladen, keine Cookies)
# Wert setzen = Analytics-Script wird eingebunden
# VITE_PLAUSIBLE_DOMAIN=buchungswerk.org
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.js
